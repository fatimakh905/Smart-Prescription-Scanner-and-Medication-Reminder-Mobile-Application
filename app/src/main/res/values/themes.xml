<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base theme. MaterialComponents is intentionally retained for
        backward-compatible widget styling (Spinner, AlertDialog, etc.)
        which Material3 equivalents may not fully cover without full migration.
    -->
    <style name="Theme.MediRemind" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/card</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.MediRemind.Splash" parent="Theme.MediRemind">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <!--
        AlarmRingActivity theme.
        android:windowShowOnLockScreen and android:turnScreenOn are
        deprecated as theme attributes (API 27+) — the actual behaviour
        is controlled in code via setShowWhenLocked() / setTurnScreenOn()
        and the manifest attributes showOnLockScreen / turnScreenOn.
        The theme items are kept for pre-API-27 compatibility only.
    -->
    <style name="Theme.MediRemind.AlarmRing" parent="Theme.MediRemind">
        <item name="android:statusBarColor">@color/primary</item>

    </style>

</resources>
